Description: Cloudfront Lambda At Edge for fronting an application.
Parameters:
  SiteDomain:
    Description: Side domain to ensure alt domains are not allowed through
    Type: String
  Environment:
    Description: Stack environment eg DEV, TRAINING
    Type: String
    Default: STAGING
    AllowedValues:
      - DEV
      - TRAINING
      - STAGING
      - PROD
Resources:

  {% set request_lambda_source = lookup('file', 'files/cloudfrontLambda.js') | replace('\n', '\n          ') %}
  {% set origin_lambda_source = lookup('file', 'files/cloudfrontOriginLambda.js') | replace('\n', '\n          ') %}

  LambdaEdgeFunction{{ request_lambda_source_hash }}:
    Type: 'AWS::Lambda::Function'
    Properties:
      Code:
        ZipFile: >
          {{ request_lambda_source }}
      Role: !GetAtt LambdaEdgeFunctionRole.Arn
      Runtime: nodejs24.x
      Handler: index.handler
      Timeout: 5

  LambdaEdgeOriginFunction{{ origin_lambda_source_hash }}:
    Type: 'AWS::Lambda::Function'
    Properties:
      Code:
        ZipFile: >
          {{ origin_lambda_source }}
      Role: !GetAtt LambdaEdgeFunctionRole.Arn
      Runtime: nodejs24.x
      Handler: index.handler
      Timeout: 5

  VersionedLambdaFunction{{ request_lambda_source_hash }}:
    Type: 'AWS::Lambda::Version'
    Properties:
      FunctionName: !Ref LambdaEdgeFunction{{ request_lambda_source_hash }}

  LambdaOriginFunctionVersion{{ origin_lambda_source_hash }}:
    Type: 'AWS::Lambda::Version'
    Properties:
      FunctionName: !Ref LambdaEdgeOriginFunction{{ origin_lambda_source_hash }}

  LambdaEdgeFunctionRole:
    Type: "AWS::IAM::Role"
    Properties:
      Path: "/"
      ManagedPolicyArns:
        - "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
      AssumeRolePolicyDocument:
        Version: "2012-10-17"
        Statement:
          -
            Sid: "AllowLambdaServiceToAssumeRole"
            Effect: "Allow"
            Action:
              - "sts:AssumeRole"
            Principal:
              Service:
                - "lambda.amazonaws.com"
                - "edgelambda.amazonaws.com"

Outputs:
  VersionedLambdaFunction:
    Value: !Ref VersionedLambdaFunction{{ request_lambda_source_hash }}

  LambdaEdgeOriginFunctionVersion:
    Value: !Ref LambdaOriginFunctionVersion{{ origin_lambda_source_hash }}
